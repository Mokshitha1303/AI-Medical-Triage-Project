# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medical_triage
REDIS_URL=redis://localhost:6379

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Pinecone (optional — omit to run in LLM-only mode)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=medical-guidelines

# Auth (required)
JWT_SECRET_KEY=change_this_to_a_long_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Notifications (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
ENVIRONMENT=development
CONFIDENCE_THRESHOLD=0.65
CORS_ORIGINS=http://localhost:3000
